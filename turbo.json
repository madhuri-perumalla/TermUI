{
    "$schema": "https://v2-9-12.turborepo.dev/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "@termuijs/example-*#build": {
            "outputs": []
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ]
        },
        "test": {
            "dependsOn": [
                "build"
            ]
        },
        "lint": {},
        "clean": {
            "cache": false
        }
    }
}